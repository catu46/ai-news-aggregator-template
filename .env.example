# =============================================================================
# Copy to .env and fill in. Do NOT commit the .env.
# =============================================================================

# --- Anthropic (Haiku 4.5 curator) ---
ANTHROPIC_API_KEY=
CURATOR_MODEL=claude-haiku-4-5
# Monthly spend cap in USD — curation PAUSES if exceeded (keeps you on budget)
CURATOR_MONTHLY_BUDGET_USD=8

# --- Curator: provider (anthropic | kimi) ---
# 'anthropic' (default) uses the Haiku above. 'kimi' uses Moonshot/Kimi (below).
CURATOR_PROVIDER=anthropic
# Only if CURATOR_PROVIDER=kimi (Moonshot/Kimi, OpenAI-compatible API):
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

# --- Voyage AI (embeddings; free for years on the 200M-token tier) ---
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-4-lite

# --- Reddit (public mode: reads the .rss/Atom feeds — NO app, login, OAuth or account) ---
# Just a descriptive User-Agent. It already has a default, so you can even leave it blank.
REDDIT_USER_AGENT=ai-news-aggregator/1.0 (personal, non-commercial)

# --- GitHub (trending repos by topic, via the public Search API) ---
# OPTIONAL: works without a token (10 searches/min); with a token it goes up to 30/min.
# Public-read-only "fine-grained" token at github.com/settings/tokens
GITHUB_TOKEN=

# --- X / Twitter (FREE mode via twitter-cli) ---
# Use a THROWAWAY X account, never your main one (ban risk).
# Extract 2 cookies from a logged-in session on x.com (DevTools or the Cookie-Editor extension):
#   cookie "auth_token"  ->  TWITTER_AUTH_TOKEN
#   cookie "ct0"         ->  TWITTER_CT0
# twitter-cli reads these two vars directly. They expire over time -> re-extract when it breaks.
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# --- Telegram (create the bot with @BotFather) ---
TELEGRAM_BOT_TOKEN=
# Your numeric Telegram ID (get it from @userinfobot). Used by the MCP server
# to know who "you" are; if empty, it falls back to the 1st user in config/sources.yaml.
TELEGRAM_USER_ID=

# --- Morning digest (the "mini-newspaper"): fixed time for the daily delivery ---
DIGEST_HOUR=7                 # 0-23, local time
DIGEST_TZ=America/Sao_Paulo   # IANA timezone

# --- Database (Supabase Free → use the POOLED connection string) ---
DATABASE_URL=

# --- Optional: Exa (supercharges the semantic search of the initial seed; free-tier) ---
EXA_API_KEY=
